# =============================================================================
# Variables d'environnement - OpenClaw
# Généré par Ansible - Ne pas modifier manuellement
# =============================================================================

# Application
NODE_ENV=production
TZ={{ timezone }}

# Token 1Password (si utilisé)
OP_SERVICE_ACCOUNT_TOKEN={{ vault_op_service_account_token | default('') }}

# Secret applicatif
OPENCLAW_SECRET={{ vault_openclaw_secret }}

# Base de données (si nécessaire)
{% if vault_postgres_password is defined and vault_postgres_password %}
DATABASE_URL=postgresql://{{ vault_postgres_user }}:{{ vault_postgres_password }}@postgres:5432/{{ vault_postgres_db }}
POSTGRES_USER={{ vault_postgres_user }}
POSTGRES_PASSWORD={{ vault_postgres_password }}
POSTGRES_DB={{ vault_postgres_db }}
{% endif %}

# SMTP (notifications)
{% if vault_smtp_host is defined and vault_smtp_host %}
SMTP_HOST={{ vault_smtp_host }}
SMTP_PORT={{ vault_smtp_port }}
SMTP_USER={{ vault_smtp_user }}
SMTP_PASS={{ vault_smtp_password }}
SMTP_FROM={{ admin_email }}
{% endif %}
