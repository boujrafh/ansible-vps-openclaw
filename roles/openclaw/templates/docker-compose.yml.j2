# =============================================================================

version: '3.8'

services:
  openclaw:
    image: ghcr.io/openclaw/openclaw:{{ openclaw_version }}
    container_name: {{ openclaw_container_name }}
    restart: unless-stopped

    # Sécurité du conteneur
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp:noexec,nosuid,size=100m

    # Limites de ressources
    deploy:
      resources:
        limits:
          cpus: '{{ openclaw_cpu_limit }}'
          memory: {{ openclaw_memory_limit }}
        reservations:
          cpus: '0.25'
          memory: 128M

    ports:
      - "127.0.0.1:{{ openclaw_port }}:8080"

    volumes:
      - {{ openclaw_config_dir }}:/app/config:ro
      - {{ openclaw_data_dir }}:/app/data:rw

    env_file:
      - .env

    networks:
      - {{ docker_network_name }}

    healthcheck:
      test: ["CMD", "wget", "-q", "--spider", "http://localhost:8080/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s

    logging:
      driver: json-file
      options:
        max-size: "{{ docker_log_max_size }}"
        max-file: "{{ docker_log_max_file }}"

networks:
  {{ docker_network_name }}:
    external: true
