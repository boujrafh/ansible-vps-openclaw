# =============================================================================
# Docker Compose - OpenClaw
# Généré par Ansible - Ne pas modifier manuellement
# =============================================================================

services:
  openclaw:
    build:
      context: .
      dockerfile: Dockerfile
    image: openclaw:local
    container_name: {{ openclaw_container_name }}
    restart: unless-stopped

    # Sécurité du conteneur
    security_opt:
      - seccomp:unconfined
      - no-new-privileges:true
    cap_add:
      - SYS_ADMIN
    cap_drop:
      - ALL

    # Limites de ressources
    deploy:
      resources:
        limits:
          cpus: '{{ openclaw_cpu_limit }}'
          memory: {{ openclaw_memory_limit }}
        reservations:
          cpus: '0.25'
          memory: 128M

    volumes:
      - {{ openclaw_config_dir }}:/app/config:rw
      - {{ openclaw_data_dir }}:/app/data:rw
      - /opt/openclaw/home:/home/node/.openclaw:rw
      - /tmp:/tmp:rw

    env_file:
      - .env

    network_mode: host

    healthcheck:
      test: ["CMD", "wget", "-q", "--spider", "--tries=1", "http://localhost:18791/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 60s

    logging:
      driver: json-file
      options:
        max-size: "{{ docker_log_max_size }}"
        max-file: "{{ docker_log_max_file }}"
