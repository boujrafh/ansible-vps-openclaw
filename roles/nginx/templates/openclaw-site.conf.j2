# =============================================================================
# Configuration OpenClaw - {{ openclaw_subdomain }}.{{ domain }}
# Généré par Ansible
# =============================================================================

# Upstream pour OpenClaw
upstream openclaw_upstream {
    server 127.0.0.1:{{ openclaw_port }};
    keepalive 32;
}

# Redirection HTTP vers HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name {{ openclaw_subdomain }}.{{ domain }};

    location / {
        return 301 https://$host$request_uri;
    }
}

# Serveur HTTPS
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ openclaw_subdomain }}.{{ domain }};

    # SSL Cloudflare Origin
    include snippets/ssl-params.conf;

    # Real IP Cloudflare
    include snippets/cloudflare-real-ip.conf;

    # Headers de sécurité
    include snippets/security-headers.conf;

    # Rate limiting
    limit_req zone=general burst={{ nginx_rate_limit_burst }} nodelay;

    # Logs spécifiques
    access_log /var/log/nginx/openclaw.access.log cloudflare;
    error_log /var/log/nginx/openclaw.error.log warn;

    # Health check
    location /health {
        access_log off;
        return 200 "OK\n";
        add_header Content-Type text/plain;
    }

    # Proxy vers OpenClaw
    location / {
        proxy_pass http://openclaw_upstream;

        # Headers de base
        include snippets/proxy-params.conf;

        # WebSocket support
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }

    # Bloquer l'accès aux fichiers sensibles
    location ~ /\.(env|git|htaccess|htpasswd) {
        deny all;
        access_log off;
        log_not_found off;
    }

    # Bloquer les requêtes suspectes
    location ~* (wp-login|wp-admin|xmlrpc|phpmyadmin|pma) {
        deny all;
        access_log off;
        log_not_found off;
    }
}
