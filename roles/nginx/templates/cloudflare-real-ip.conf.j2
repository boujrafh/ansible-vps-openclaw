# =============================================================================
# Restauration des IPs réelles Cloudflare
# Généré par Ansible
# =============================================================================

# IPs Cloudflare IPv4
{% for ip in cloudflare_ips_v4 %}
set_real_ip_from {{ ip }};
{% endfor %}

# Header contenant l'IP réelle
real_ip_header CF-Connecting-IP;
real_ip_recursive on;
